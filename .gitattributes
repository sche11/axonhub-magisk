# Use LF line endings for all text files (critical for shell scripts run on Linux CI)
* text=auto eol=lf

# Explicit LF for shell scripts and Unix-only files
*.sh         text eol=lf
*.yml        text eol=lf
*.yaml       text eol=lf
*.json       text eol=lf
*.html       text eol=lf
*.prop       text eol=lf
*.gitignore  text eol=lf

# Binary files
*.zip        binary
*.png        binary
*.jpg        binary
*.so         binary
*.aar        binary
